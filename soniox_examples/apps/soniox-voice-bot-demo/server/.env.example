SONIOX_API_KEY=

OPENAI_API_KEY=
OPENAI_MODEL=

# ── Clover POS ────────────────────────────────────────────────────────────────
# Sandbox:    https://apisandbox.dev.clover.com
# Production: https://api.clover.com
CLOVER_BASE_URL=https://apisandbox.dev.clover.com

# 13-character alphanumeric ID from the Clover dashboard URL bar
CLOVER_MERCHANT_ID=

# Bearer token — sandbox: generate in merchant dashboard → Settings → API Tokens
# Production: obtain via OAuth flow
CLOVER_ACCESS_TOKEN=

# Single-use refresh token for production token rotation.
# Leave empty for sandbox (sandbox tokens don't expire).
CLOVER_REFRESH_TOKEN=

# Secret set during Clover webhook registration.
# Used to validate the X-Clover-Auth header on every incoming webhook.
CLOVER_WEBHOOK_SECRET=

# Seconds between background delta-sync polls (fallback if webhook delivery fails).
# Default 300 = 5 minutes.
CLOVER_MENU_POLL_INTERVAL=300

# ── Square POS (optional — enables Square mode when set) ─────────────────────
# Sandbox:    https://connect.squareupsandbox.com
# Production: https://connect.squareup.com
SQUARE_BASE_URL=https://connect.squareupsandbox.com

# Sandbox/production access token from developer.squareup.com
SQUARE_ACCESS_TOKEN=

# Location ID from your Square sandbox/production dashboard
SQUARE_LOCATION_ID=
