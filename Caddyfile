:80 {
    @browser_ws path /ws
    handle @browser_ws {
        reverse_proxy voice-server:8765
    }

    @store_api path /store-api /store-api/*
    handle @store_api {
        uri strip_prefix /store-api
        reverse_proxy store-api:8766
    }

    @twilio path /incoming-call /transfer-twiml /media-stream /clover-webhook
    handle @twilio {
        reverse_proxy twilio-bridge:5050
    }

    handle {
        reverse_proxy frontend:80
    }
}
